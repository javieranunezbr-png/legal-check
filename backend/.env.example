PORT=3001

# PostgreSQL — Railway inyecta DATABASE_URL automáticamente.
# En producción (Railway) solo se necesita DATABASE_URL.
# En desarrollo local usa las variables individuales como fallback.
DATABASE_URL=postgresql://usuario:password@host:5432/dbname

DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_check
DB_USER=postgres
DB_PASSWORD=tu_password

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# Frontend (para construir los links públicos en correos)
FRONTEND_URL=http://localhost:5173

# Resend (envío de correos de presupuestos) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Debe ser un dominio verificado en Resend. Para pruebas puedes usar:
# RESEND_FROM="Law Kit <onboarding@resend.dev>"
RESEND_FROM="Law Kit <no-reply@tu-dominio.cl>"
